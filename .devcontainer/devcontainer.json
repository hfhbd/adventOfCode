{
    "image": "mcr.microsoft.com/devcontainers/base:alpine",
    "features": {
        "ghcr.io/devcontainers/features/sshd:1": {},
        "ghcr.io/devcontainers/features/java:1": {
            "version": "25"
        },
        "./installKotlinLsp": {}
    },
    "onCreateCommand": "./gradlew build",
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-gradle"
            ]
        }
    }
}
